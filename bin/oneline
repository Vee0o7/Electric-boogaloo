#!/usr/bin/env bash

# exit if stdin is connected to terminal (script should filter piped input)
[[ -t 0 ]] && exit 0

: "${COLUMNS:=$(tput cols)}"
clear_str=$'\r'"$(printf "%$((COLUMNS-2))s" ' ')"$'\r'

while IFS= read -r line; do
  [[ -n "$line" ]] || continue
  printf '%s%s' "$clear_str" "${line:0:$COLUMNS}"
done
