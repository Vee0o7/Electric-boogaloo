#!/usr/bin/env bash

SCRIPT_DIR=$HOME/.dotfiles/
cd "$SCRIPT_DIR" || exit
true > switch.log
wm="gnome"
rebuild="false"

usage() {
	cat <<EOF

Usage: $0 [OPTION]...
Syncs home-manager with working flakes and commits to git

OPTIONS:
  -h, --help              Show help
  -f, --fast              Only update config (--no-reexec)
EOF
}

while [[ $# -gt 0 ]]; do
        case "${1}" in
        --hypr)
                wm="hypr"
                shift
                ;;
        --gnome)
                wm="gnome"
                shift
                ;;
        -r | --rebuild)
                rebuild="true"
                shift
                ;;
        -h | --help)
                usage
                exit 0
                ;;
        *) 
                echo "ERROR: Unrecognized option '$1'."
                echo "Try '$0 --help' for more infomation."
                exit 1
                ;;
        esac
done


case "$wm" in
        gnome)
                ;;
        hypr)
                ;;
esac

command="sudo nixos-rebuild switch --flake $SCRIPT_DIR"
gencmd="nixos-rebuild list-generations"
gengrep="grep True"

gdiff=$(git diff -U0 HEAD~1)
if [[ "$gdiff" != "" ]]; then
        echo "$gdiff" | $EDITOR -R
else
        echo "no changes to commit"
fi

script -qfae -c "$command"  -O >(ansifilter >> "$SCRIPT_DIR/switch.log") || exit
gen=$($gencmd | $gengrep)
if [[ "$gen" != "$(git log --pretty=%B | grep "$gen")" ]]; then
        git commit -am "$gen"
fi
